        order_id,
        driver_id,
        warehouse_id,

        -- Normalise delivery status as lowercase
        lower(delivery_status) as delivery_status,
        lower(delivery_type)   as delivery_type,

        attempted_at,
        delivered_at,

        -- Delivery completion timestamp (placeholder for nulls)
        coalesce(delivered_at, attempted_at) as delivery_event_ts,

        -- Was the delivery completed?
        case 
            when delivered_at is not null then true
            else false
        end as is_completed
    from deliveries
