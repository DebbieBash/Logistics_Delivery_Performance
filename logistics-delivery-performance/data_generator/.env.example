# Copy to .env and fill in, OR export these in your shell before running.
# The script reads them from the environment; it does not parse .env itself,
# so either `export $(grep -v '^#' .env | xargs)` or use a tool like direnv.

SNOWFLAKE_ACCOUNT=xy12345.us-east-1     # your account identifier
SNOWFLAKE_USER=FELLOW_NAME
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=SYSADMIN                  # a role that can create db/schema/tables
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=HAULPOINT             # created if it doesn't exist
SNOWFLAKE_SCHEMA=RAW                     # created if it doesn't exist
